{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Rose Glass",
  "version": "0.5.1",
  "identifier": "lab.home.roseglass",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Rose Glass",
        "width": 1400,
        "height": 900,
        "minWidth": 920,
        "minHeight": 600,
        "decorations": false,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; worker-src 'self' blob:; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "windows": {
      "certificateThumbprint": "FF91E3867E3DE0BF3AAC34AF0E752D7CC54D2B11",
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["md", "markdown"],
        "name": "Markdown",
        "description": "Markdown document",
        "role": "Editor"
      },
      {
        "ext": ["txt"],
        "name": "Plain Text",
        "description": "Plain text document",
        "role": "Editor"
      },
      {
        "ext": ["pdf"],
        "name": "PDF",
        "description": "PDF document",
        "role": "Viewer"
      },
      {
        "ext": ["docx"],
        "name": "Word Document",
        "description": "Word document",
        "role": "Viewer"
      }
    ]
  }
}
